[System: UDF]
UdyamNo : String : 10001
FssaiNo : String : 10002

[#Part: Company Info]
Add : Line : After : Company Name : UdyamLine

[Line: UdyamLine]
Fields : Long Prompt, UdyamField

[Field: UdyamField]
Use : Name Field
Storage : UdyamNo

[#Part: Company Info]
Add : Line : After : UdyamLine : FssaiLine

[Line: FssaiLine]
Fields : Long Prompt, FssaiField

[Field: FssaiField]
Use : Name Field
Storage : FssaiNo
